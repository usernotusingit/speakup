generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role                String    @default("student")
  speakupCalendarId   String?   @unique
  accounts            Account[]
  sessions      Session[]
  turmas        Turma[]
  enrollments         Enrollment[]
  lessonNotes         LessonNote[]
  bookings            Booking[]
}

model LessonNote {
  id        String   @id @default(cuid())
  userId    String
  bookId    Int
  lessonId  Int
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId, lessonId])
  @@index([userId])
}

model Enrollment {
  id           String   @id @default(cuid())
  studentEmail String
  teacherId    String
  teacher      User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([studentEmail, teacherId])
  @@index([studentEmail])
  @@index([teacherId])
}

model Booking {
  id            String   @id @default(cuid())
  studentEmail  String
  studentName   String?
  teacherId     String
  teacher       User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  start         DateTime
  end           DateTime
  summary       String   @default("English Class")
  status        String   @default("pending") // pending | confirmed | declined
  googleEventId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([teacherId, status])
  @@index([studentEmail, status])
  @@index([teacherId, start])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Turma {
  id        String     @id @default(cuid())
  code      String     @unique
  level     String
  teacher   User       @relation(fields: [teacherId], references: [id])
  teacherId String
  schedules Schedule[]

  @@index([teacherId])
}

model Schedule {
  id      String @id @default(cuid())
  turmaId String
  day     String
  start   String
  end     String
  turma   Turma  @relation(fields: [turmaId], references: [id])

  @@index([turmaId])
}
